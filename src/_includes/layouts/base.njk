<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{{ title }}</title>
		{%- set inlinecss %}{% getBundle "css", "inline" %}{% endset -%}
		{% if inlinecss %}
		<style>
			{{ inlinecss | safe }}
		</style>
		{%- endif %}
		<link rel="stylesheet" href="/css/base.css">
		{%- getBundle "html", "head" %}
	</head>
	<body>
		{{ content | safe}}
	</body>
</html>
