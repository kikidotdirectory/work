<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{{ title }}</title>
		{{ if inlinecss }}
			<style> {{ inlinecss }} </style>
		{{ /if }}
		{{ if head }}
			{{ head }}
		{{ /if }}
		{{ include "partials/head-stylesheet.vto"}}
	</head>
	<body>
		{{ content }}
	</body>
</html>
